@using Microsoft.AspNetCore.Identity
@using WFRP_Character_Companion.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var appUser = await UserManager.GetUserAsync(User);
}

@if (SignInManager.IsSignedIn(User))
{
    <div class="flex items-center gap-3">
        @if (appUser?.AvatarFileName != null)
        {
            <img src="/avatars/@appUser.AvatarFileName" alt="" class="h-8 w-8 rounded-full object-cover ring-1 ring-stone-700" />
        }
        <a asp-page="/Profile" class="truncate text-sm text-stone-300 hover:text-amber-400">
            @(string.IsNullOrWhiteSpace(appUser?.DisplayName) ? "Profil" : appUser.DisplayName)
        </a>
    </div>
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")" class="mt-2">
        <button type="submit" class="w-full rounded-lg px-3 py-2 text-left text-sm text-stone-400 transition hover:bg-stone-800 hover:text-red-300">
            Wyloguj się
        </button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="block rounded-lg px-3 py-2 text-sm text-stone-300 hover:bg-stone-800">Logowanie</a>
    <a asp-area="Identity" asp-page="/Account/Register" class="mt-1 block rounded-lg px-3 py-2 text-sm text-stone-400 hover:bg-stone-800">Rejestracja</a>
}
