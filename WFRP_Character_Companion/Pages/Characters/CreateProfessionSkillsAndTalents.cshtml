@page
@model WFRP_Character_Companion.Pages.Characters.CreateProfessionSkillsAndTalentsModel

<h2>Tworzenie postaci — Rozwój profesji (Tier 1)</h2>

<div class="card p-3">
    <p>Rozdziel 40 punktów między umiejętności wymienione w Tier 1 Twojej profesji jako rozwinięcia.</p>

    @if (!string.IsNullOrEmpty(Model.FoundProfessionName))
    {
        <p class="text-muted">Profesja: <strong>@Model.FoundProfessionName</strong></p>
    }

    @if (!Model.TierSkills.Any())
    {
        <p class="text-muted">Brak umiejętności w Tier 1 tej profesji.</p>
    }

    <form method="post">
        @if (Model.TierSkills.Any())
        {
            <table class="table">
                <thead><tr><th>Umiejętność</th><th>Punkty</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < Model.TierSkills.Count; i++)
                    {
                        var s = Model.TierSkills[i];
                        <tr>
                            <td>@s</td>
                            <td><input type="number" name="pts_@i" class="form-control" min="0" value="0" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <hr />

        <h5>Wybierz 1 talent z Tier 1</h5>
        @if (Model.TierTalents.Any())
        {
            <select name="chosenTalent" class="form-select mb-3">
                <option value="">— wybierz —</option>
                @foreach (var t in Model.TierTalents)
                {
                    <option value="@t">@t</option>
                }
            </select>
        }
        else
        {
            <p class="text-muted">Brak talentów w Tier 1 tej profesji.</p>
        }

        <button class="btn btn-primary">Zatwierdź</button>
    </form>
</div>
