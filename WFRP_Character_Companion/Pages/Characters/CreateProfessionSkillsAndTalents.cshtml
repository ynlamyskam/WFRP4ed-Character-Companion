@page
@model WFRP_Character_Companion.Pages.Characters.CreateProfessionSkillsAndTalentsModel
@{
    ViewData["Title"] = "Profesja — rozwój";
}

@await Html.PartialAsync("_CreationProgress", 9)
<partial name="_ErrorAlert" />

<h1 class="font-display mb-2 text-2xl font-bold text-amber-500 sm:text-3xl">Rozwój profesji</h1>
@if (!string.IsNullOrEmpty(Model.FoundProfessionName))
{
    <p class="mb-6 text-stone-400">Profesja: <span class="text-stone-200">@Model.FoundProfessionName</span></p>
}

<div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
    <form method="post" data-validate="profession-points" class="space-y-6">
        @if (Model.TierSkills.Any())
        {
            <section>
                <p class="mb-2 text-stone-400">Rozdziel dokładnie <strong class="text-amber-400">40</strong> punktów między umiejętności Tier 1.</p>
                <p class="mb-4 text-sm text-stone-500">Przydzielono: <span data-live-sum data-target="40" data-sum-selector="input[name^=&quot;pts_&quot;]" class="font-mono font-bold">0</span> / 40</p>
                <div class="space-y-2">
                    @for (int i = 0; i < Model.TierSkills.Count; i++)
                    {
                        <label class="flex items-center justify-between gap-3 rounded-lg border border-stone-700 bg-stone-800/50 px-3 py-2">
                            <span class="text-sm text-stone-300">@Model.TierSkills[i]</span>
                            <input type="number" name="pts_@i" min="0" value="0" class="w-20 rounded border border-stone-600 bg-stone-900 px-2 py-1 text-center text-stone-100" />
                        </label>
                    }
                </div>
            </section>
        }
        else
        {
            <p class="text-stone-500">Brak umiejętności w Tier 1 tej profesji.</p>
        }

        @if (Model.TierTalents.Any())
        {
            <section>
                <label class="mb-1 block text-sm text-stone-400">Talent Tier 1 (wymagany)</label>
                <select name="chosenTalent" required class="w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100">
                    <option value="">— wybierz —</option>
                    @foreach (var t in Model.TierTalents) { <option value="@t">@t</option> }
                </select>
            </section>
        }

        <button type="submit" class="rounded-lg bg-amber-800 px-6 py-3 font-medium text-white transition hover:bg-amber-700">Zatwierdź</button>
    </form>
</div>
