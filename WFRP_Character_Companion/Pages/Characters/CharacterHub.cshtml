@page
@model WFRP_Character_Companion.Pages.Characters.CharacterHubModel
@{
    ViewData["Title"] = "Postacie";
}

<h1 class="font-display mb-2 text-2xl font-bold text-amber-500 sm:text-3xl">Twoje postacie</h1>
<p class="mb-8 text-stone-400">Zarządzaj swoimi postaciami do WFRP 4ed.</p>

<a asp-page="/Characters/CreateRace"
   class="mb-8 inline-flex items-center gap-2 rounded-lg bg-emerald-800 px-5 py-3 font-medium text-white transition hover:bg-emerald-700">
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Nowa postać
</a>

@if (Model.Characters.Count == 0)
{
    <div class="rounded-xl border border-dashed border-stone-700 bg-stone-900/50 px-6 py-12 text-center">
        <p class="text-stone-500">Nie masz jeszcze żadnych postaci.</p>
    </div>
}
else
{
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var c in Model.Characters)
        {
            <a asp-page="/Characters/Details" asp-route-id="@c.Id"
               class="group rounded-xl border border-stone-700 bg-stone-900/80 p-5 transition hover:border-amber-800/50 hover:bg-stone-900">
                <h2 class="font-display text-lg font-semibold text-stone-100 group-hover:text-amber-400">@c.Name</h2>
                <p class="mt-1 text-xs text-stone-500">Kliknij, aby otworzyć kartę</p>
            </a>
        }
    </div>
}
