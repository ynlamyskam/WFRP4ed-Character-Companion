@page
@model WFRP_Character_Companion.Pages.Characters.CharacterHubModel

<h2>Twoje postacie</h2>

@if (Model.Characters.Count == 0)
{
    <p>Nie masz jeszcze żadnych postaci.</p>
}
else
{
    <ul>
        @foreach (var c in Model.Characters)
        {
            <li>
                <a asp-page="/Characters/Details" asp-route-id="@c.Id">
                    @c.Name
                </a>
            </li>
        }
    </ul>
}