@page
@model WFRP_Character_Companion.Pages.Characters.CreateEquipmentModel
@{
    ViewData["Title"] = "Ekwipunek";
}

@await Html.PartialAsync("_CreationProgress", 10)
<partial name="_ErrorAlert" />

<h1 class="font-display mb-6 text-2xl font-bold text-amber-500 sm:text-3xl">Ekwipunek</h1>

<div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
    <form method="post" class="mb-6 flex flex-col gap-3 sm:flex-row">
        <input type="text" name="item" placeholder="Nazwa przedmiotu"
               class="flex-1 rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100 placeholder-stone-500 focus:border-amber-600 focus:outline-none focus:ring-1 focus:ring-amber-600" />
        <button type="submit" class="rounded-lg bg-stone-700 px-4 py-2 text-stone-200 transition hover:bg-stone-600">Dodaj</button>
    </form>

    @if (Model.Items.Any())
    {
        <ul class="mb-6 divide-y divide-stone-800 rounded-lg border border-stone-700">
            @foreach (var it in Model.Items)
            {
                <li class="px-4 py-2 text-stone-300">@it</li>
            }
        </ul>
    }
    else
    {
        <p class="mb-6 text-sm text-stone-500">Brak przedmiotów — możesz pominąć i przejść dalej.</p>
    }

    <form method="post" asp-page-handler="Finish">
        <button type="submit" class="rounded-lg bg-emerald-800 px-6 py-3 font-medium text-white transition hover:bg-emerald-700">
            Dalej — ostatnie szczegóły
        </button>
    </form>
</div>
