@page
@model WFRP_Character_Companion.Pages.Characters.CreateRaceSkillsAndTalentsModel
@{
    ViewData["Title"] = "Umiejętności pochodzenia";
}

@await Html.PartialAsync("_CreationProgress", 8)
<partial name="_ErrorAlert" />

<h1 class="font-display mb-2 text-2xl font-bold text-amber-500 sm:text-3xl">Talenty i umiejętności</h1>
<p class="mb-6 text-stone-400">Pochodzenie: <span class="text-stone-200">@Model.OriginName</span></p>

<div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
    <form method="post" data-validate="origin-skills" class="space-y-6">

        @if (Model.FixedTalents.Any())
        {
            <section>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Stałe talenty</h2>
                <ul class="list-inside list-disc text-stone-300">
                    @foreach (var t in Model.FixedTalents) { <li>@t</li> }
                </ul>
            </section>
        }

        @if (Model.RandomTalents.Any())
        {
            <section>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Wylosowane talenty</h2>
                <ul class="list-inside list-disc text-amber-300">
                    @foreach (var t in Model.RandomTalents) { <li>@t</li> }
                </ul>
            </section>
        }

        @if (Model.ChoiceTalentGroups.Any())
        {
            <section>
                <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-stone-500">Wybierz talenty</h2>
                @for (int i = 0; i < Model.ChoiceTalentGroups.Count; i++)
                {
                    <label class="mb-3 block">
                        <span class="mb-1 block text-sm text-stone-400">Wybór @(i + 1)</span>
                        <select name="talent_choice_@i" class="w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100">
                            @foreach (var opt in Model.ChoiceTalentGroups[i])
                            { <option value="@opt">@opt</option> }
                        </select>
                    </label>
                }
            </section>
        }

        @if (Model.OriginSkills.Any())
        {
            <section>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Bonusy do umiejętności</h2>
                <p class="mb-4 text-sm text-stone-400">Do 3× +3 i do 3× +5 (max 6 różnych umiejętności, bez duplikatów).</p>
                <div class="grid gap-6 md:grid-cols-2">
                    <div>
                        <h3 class="mb-2 text-amber-600">+3 punkty</h3>
                        @for (int i = 0; i < 3; i++)
                        {
                            <select name="skill_plus3_@i" class="mb-2 w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-sm text-stone-100">
                                <option value="">— brak —</option>
                                @foreach (var s in Model.OriginSkills) { <option value="@s">@s</option> }
                            </select>
                        }
                    </div>
                    <div>
                        <h3 class="mb-2 text-amber-600">+5 punktów</h3>
                        @for (int i = 0; i < 3; i++)
                        {
                            <select name="skill_plus5_@i" class="mb-2 w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-sm text-stone-100">
                                <option value="">— brak —</option>
                                @foreach (var s in Model.OriginSkills) { <option value="@s">@s</option> }
                            </select>
                        }
                    </div>
                </div>
            </section>
        }

        <button type="submit" class="rounded-lg bg-amber-800 px-6 py-3 font-medium text-white transition hover:bg-amber-700">
            Zatwierdź pochodzenie
        </button>
    </form>
</div>
