@page
@model WFRP_Character_Companion.Pages.Characters.CreateRaceSkillsAndTalentsModel
@{
    ViewData["Title"] = "Umiejętności pochodzenia";
}

@await Html.PartialAsync("_CreationProgress", 8)
<partial name="_ErrorAlert" />

<h1 class="font-display mb-2 text-2xl font-bold text-amber-500 sm:text-3xl">Talenty i umiejętności</h1>
<p class="mb-6 text-stone-400">Pochodzenie: <span class="text-stone-200">@Model.OriginName</span></p>

<div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
    <form method="post" data-validate="origin-skills" data-origin-skill-bonuses class="space-y-6">

        @if (Model.FixedTalents.Any())
        {
            <section>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Stałe talenty</h2>
                <ul class="space-y-3">
                    @foreach (var t in Model.FixedTalents)
                    {
                        <li class="text-stone-300">
                            @t.Display
                            @if (t.AllowsCustomSpecialization)
                            {
                                <input type="text" name="fixed_talent_spec_@t.Name" placeholder="Wpisz specjalizację…" required
                                       class="ml-2 w-full max-w-xs rounded-lg border border-stone-600 bg-stone-800 px-3 py-1.5 text-sm text-stone-100 sm:inline-block" />
                            }
                        </li>
                    }
                </ul>
            </section>
        }

        @if (Model.RandomTalents.Any())
        {
            <section>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Wylosowane talenty</h2>
                <ul class="list-inside list-disc text-amber-300">
                    @foreach (var t in Model.RandomTalents) { <li>@t</li> }
                </ul>
            </section>
        }

        @if (Model.ChoiceTalentGroups.Any())
        {
            <section>
                <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-stone-500">Wybierz talenty</h2>
                @for (int i = 0; i < Model.ChoiceTalentGroups.Count; i++)
                {
                    var hasCustom = Model.ChoiceTalentGroups[i].Any(o => o.AllowsCustomSpecialization);
                    <div class="mb-4 rounded-lg border border-stone-700 bg-stone-800/40 p-4">
                        <label class="mb-2 block text-sm text-stone-400">Wybór @(i + 1)</label>
                        <select name="talent_choice_@i" class="w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100"
                                @if (hasCustom) { <text>data-talent-choice="@i"</text> }>
                            @foreach (var opt in Model.ChoiceTalentGroups[i])
                            {
                                <option value="@opt.Key" data-custom="@(opt.AllowsCustomSpecialization ? "1" : "0")">@opt.Display</option>
                            }
                        </select>
                        @if (hasCustom)
                        {
                            <input type="text" name="talent_custom_spec_@i" placeholder="Specjalizacja (gdy wymagana)…"
                                   class="mt-2 w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-sm text-stone-100" />
                        }
                    </div>
                }
            </section>
        }

        @if (Model.OriginSkills.Any())
        {
            <section>
                <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Bonusy do umiejętności</h2>
                <p class="mb-2 text-sm text-stone-400">
                    Przy każdej umiejętności wybierz <strong class="text-amber-400">+3</strong> lub <strong class="text-amber-400">+5</strong>
                    (nie oba naraz). Łącznie do 3× +3 i 3× +5.
                </p>
                <p class="mb-4 text-sm text-stone-500">
                    Wybrano: <span data-count-plus3 class="font-mono font-bold">0</span>/3 na +3,
                    <span data-count-plus5 class="font-mono font-bold">0</span>/3 na +5
                </p>
                <div class="overflow-x-auto rounded-lg border border-stone-700">
                    <table class="w-full min-w-[480px] text-sm">
                        <thead class="bg-stone-800/80 text-left text-stone-400">
                            <tr>
                                <th class="px-4 py-2">Umiejętność</th>
                                <th class="px-3 py-2 text-center w-16">+3</th>
                                <th class="px-3 py-2 text-center w-16">+5</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-stone-800">
                            @for (int i = 0; i < Model.OriginSkills.Count; i++)
                            {
                                var s = Model.OriginSkills[i];
                                <tr data-skill-row class="text-stone-300">
                                    <td class="px-4 py-3">
                                        <span class="text-stone-100">@s.Display</span>
                                        @if (s.AllowsCustomSpecialization)
                                        {
                                            <input type="text" name="skill_custom_spec_@i" data-custom-spec placeholder="Wpisz specjalizację…"
                                                   class="mt-1 w-full rounded border border-stone-600 bg-stone-900 px-2 py-1 text-sm text-stone-100" />
                                        }
                                    </td>
                                    <td class="px-3 py-3 text-center">
                                        <input type="radio" name="skill_bonus_@i" value="3" class="h-4 w-4 accent-amber-600" />
                                    </td>
                                    <td class="px-3 py-3 text-center">
                                        <input type="radio" name="skill_bonus_@i" value="5" class="h-4 w-4 accent-amber-600" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        <button type="submit" class="rounded-lg bg-amber-800 px-6 py-3 font-medium text-white transition hover:bg-amber-700">
            Zatwierdź pochodzenie
        </button>
    </form>
</div>

@section Scripts {
    <script src="~/js/origin-skill-bonuses.js" asp-append-version="true"></script>
}
