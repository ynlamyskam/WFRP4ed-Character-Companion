@page
@model WFRP_Character_Companion.Pages.Characters.CreateFateAndResillienceModel
@{
    ViewData["Title"] = "Przeznaczenie";
}

@await Html.PartialAsync("_CreationProgress", 7)
<partial name="_ErrorAlert" />

<h1 class="font-display mb-2 text-2xl font-bold text-amber-500 sm:text-3xl">Przeznaczenie i Bohaterstwo</h1>
<p class="mb-6 text-stone-400">Rasa: <span class="text-stone-200">@Model.RaceName</span></p>

<div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
    <div class="mb-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-lg border border-stone-600 bg-stone-800/50 px-4 py-3">
            <p class="text-xs uppercase tracking-wide text-stone-500">Bazowe PP</p>
            <p class="font-display text-2xl font-bold text-amber-400">@Model.FateBase</p>
        </div>
        <div class="rounded-lg border border-stone-600 bg-stone-800/50 px-4 py-3">
            <p class="text-xs uppercase tracking-wide text-stone-500">Bazowe PB</p>
            <p class="font-display text-2xl font-bold text-amber-400">@Model.ResilienceBase</p>
        </div>
    </div>

    <p class="mb-2 text-stone-400">Rozdziel <strong class="text-amber-400">@Model.PointsToSpend</strong> dodatkowych punktów.</p>
    <p class="mb-4 text-sm text-stone-500">Suma: <span data-live-sum data-target="@Model.PointsToSpend" data-sum-selector="[name='FateBonus'], [name='ResilienceBonus']" class="font-mono font-bold">@(Model.FateBonus + Model.ResilienceBonus)</span> / @Model.PointsToSpend</p>

    <form method="post" data-validate="fate-pool" data-pool="@Model.PointsToSpend" class="space-y-4">
        <div>
            <label class="mb-1 block text-sm text-stone-400">Dodatkowe Punkty Przeznaczenia</label>
            <input type="number" name="FateBonus" min="0" max="@Model.PointsToSpend" value="@Model.FateBonus"
                   class="w-full max-w-xs rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100 focus:border-amber-600 focus:outline-none focus:ring-1 focus:ring-amber-600" />
        </div>
        <div>
            <label class="mb-1 block text-sm text-stone-400">Dodatkowe Punkty Bohatera</label>
            <input type="number" name="ResilienceBonus" min="0" max="@Model.PointsToSpend" value="@Model.ResilienceBonus"
                   class="w-full max-w-xs rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100 focus:border-amber-600 focus:outline-none focus:ring-1 focus:ring-amber-600" />
        </div>
        <div>
            <label class="mb-1 block text-sm text-stone-400">Motywacja</label>
            <input type="text" name="Motivation" value="@Model.Motivation"
                   class="w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100 focus:border-amber-600 focus:outline-none focus:ring-1 focus:ring-amber-600" />
        </div>
        <button type="submit" class="rounded-lg bg-amber-800 px-6 py-3 font-medium text-white transition hover:bg-amber-700">Zatwierdź</button>
    </form>
</div>
