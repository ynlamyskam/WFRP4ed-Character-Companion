@page
@model WFRP_Character_Companion.Pages.Characters.CreateAttributesModel
@{
    ViewData["Title"] = "Cechy";
}

@await Html.PartialAsync("_CreationProgress", 5)
<partial name="_ErrorAlert" />

<h1 class="font-display mb-6 text-2xl font-bold text-amber-500 sm:text-3xl">Cechy</h1>

<div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
    @if (Model.Stage == "roll")
    {
        <p class="mb-4 text-stone-400">Wylosowano zestaw 2k10 dla każdej cechy.</p>
        <div class="mb-6 overflow-x-auto">
            <table class="w-full min-w-[320px] text-left text-sm">
                <thead class="border-b border-stone-700 text-stone-400">
                    <tr><th class="py-2 pr-4">Cecha</th><th class="py-2 pr-4">Baza</th><th class="py-2 pr-4">2k10</th><th class="py-2">Wynik</th></tr>
                </thead>
                <tbody class="divide-y divide-stone-800">
                    @for (int i = 0; i < Model.AttributeOrder.Count; i++)
                    {
                        var t = Model.AttributeOrder[i];
                        <tr>
                            <td class="py-2 pr-4 text-stone-200">@t</td>
                            <td class="py-2 pr-4">@Model.Bases[t]</td>
                            <td class="py-2 pr-4 font-mono text-amber-400">@Model.Rolls[i]</td>
                            <td class="py-2 font-semibold">@(Model.Bases[t] + Model.Rolls[i])</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <form method="post" asp-page-handler="AcceptRoll">
                <button type="submit" class="rounded-lg bg-emerald-800 px-4 py-2 font-medium text-white transition hover:bg-emerald-700">Akceptuję (+50 PD)</button>
            </form>
            <form method="post" asp-page-handler="Rearrange">
                <button type="submit" class="rounded-lg bg-amber-800 px-4 py-2 font-medium text-white transition hover:bg-amber-700">Przestaw 2k10 (+25 PD)</button>
            </form>
            <form method="post" asp-page-handler="ManualAllocate">
                <button type="submit" class="rounded-lg bg-stone-700 px-4 py-2 text-stone-200 transition hover:bg-stone-600">Ręczne 100 pkt (bez PD)</button>
            </form>
        </div>
    }
    else if (Model.Stage == "rearrange")
    {
        <p class="mb-4 text-stone-400">Przestaw wylosowane wartości między cechami.</p>
        <form method="post" asp-page-handler="AcceptRearrange" data-validate="rearrange-rolls">
            <div class="mb-4 overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="border-b border-stone-700 text-stone-400"><tr><th class="py-2">Cecha</th><th class="py-2">Roll</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < Model.AttributeOrder.Count; i++)
                        {
                            <tr class="border-b border-stone-800">
                                <td class="py-2 pr-4">@Model.AttributeOrder[i]</td>
                                <td class="py-2">
                                    <select name="rollIndex_@i" class="rounded-lg border border-stone-600 bg-stone-800 px-2 py-1 text-stone-100">
                                        @for (int j = 0; j < Model.Rolls.Count; j++)
                                        { <option value="@j">@Model.Rolls[j]</option> }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="rounded-lg bg-emerald-800 px-4 py-2 text-white hover:bg-emerald-700">Zatwierdź (+25 PD)</button>
            </div>
        </form>
        <form method="post" asp-page-handler="CancelRearrange" class="mt-3">
            <button type="submit" class="text-sm text-stone-400 hover:text-stone-200">Anuluj</button>
        </form>
    }
    else if (Model.Stage == "manual")
    {
        <p class="mb-4 text-stone-400">Rozdziel 100 punktów (4–18 każda cecha, bazy zostają).</p>
        <form method="post" asp-page-handler="AcceptManual" data-validate="manual-100">
            <div class="mb-4 grid gap-3 sm:grid-cols-2">
                @for (int i = 0; i < Model.AttributeOrder.Count; i++)
                {
                    <label class="flex items-center justify-between gap-3 rounded-lg border border-stone-700 bg-stone-800/50 px-3 py-2">
                        <span class="text-sm text-stone-300">@Model.AttributeOrder[i]</span>
                        <input type="number" name="manual_@i" min="4" max="18" value="10" class="w-20 rounded border border-stone-600 bg-stone-900 px-2 py-1 text-center text-stone-100" />
                    </label>
                }
            </div>
            <button type="submit" class="rounded-lg bg-emerald-800 px-4 py-2 text-white hover:bg-emerald-700">Zatwierdź</button>
        </form>
    }
    else if (Model.Stage == "advance")
    {
        @if (Model.AdvanceAttributes.Any())
        {
            <p class="mb-2 text-stone-400">Rozdziel dokładnie <strong class="text-amber-400">5</strong> punktów rozwinięć (Tier 1 profesji).</p>
            <p class="mb-4 text-sm text-stone-500">Przydzielono: <span data-live-sum data-target="5" data-sum-selector="input[name^=&quot;advance_&quot;]" class="font-mono font-bold">0</span> / 5</p>
            <form method="post" asp-page-handler="AcceptAdvances" data-validate="advance-points" data-target="5">
                <div class="mb-4 space-y-2">
                    @for (int i = 0; i < Model.AdvanceAttributes.Count; i++)
                    {
                        <label class="flex items-center justify-between gap-3 rounded-lg border border-stone-700 bg-stone-800/50 px-3 py-2">
                            <span class="text-sm text-stone-300">@Model.AdvanceAttributes[i]</span>
                            <input type="number" name="advance_@i" min="0" max="5" value="0" class="w-20 rounded border border-stone-600 bg-stone-900 px-2 py-1 text-center text-stone-100" />
                        </label>
                    }
                </div>
                <button type="submit" class="rounded-lg bg-emerald-800 px-4 py-2 text-white hover:bg-emerald-700">Zatwierdź rozwinięcia</button>
            </form>
        }
        else
        {
            <p class="mb-4 text-yellow-200/80">Nie znaleziono cech Tier 1 dla profesji.</p>
            <form method="post" asp-page-handler="AcceptAdvances">
                <button type="submit" class="rounded-lg bg-emerald-800 px-4 py-2 text-white hover:bg-emerald-700">Kontynuuj</button>
            </form>
        }
    }
</div>

@section Scripts {
    <script>
        (function(){
            const selects = document.querySelectorAll('select[name^="rollIndex_"]');
            function updateOptions() {
                const chosen = Array.from(selects).map(s => s.value);
                selects.forEach(s => {
                    Array.from(s.options).forEach(opt => {
                        opt.disabled = chosen.includes(opt.value) && s.value !== opt.value;
                    });
                });
            }
            selects.forEach(s => s.addEventListener('change', updateOptions));
            updateOptions();
        })();
    </script>
}
