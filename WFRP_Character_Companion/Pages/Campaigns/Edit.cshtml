@page "{id:int}"
@model WFRP_Character_Companion.Pages.Campaigns.EditModel
@{
    ViewData["Title"] = "Edycja kampanii";
}

<a asp-page="/Campaigns/CampaignHub" class="mb-6 inline-block text-sm text-stone-500 transition hover:text-amber-400">&larr; Wróć do kampanii</a>

<h1 class="font-display mb-1 text-2xl font-bold text-amber-500 sm:text-3xl">@Model.CampaignName</h1>
<p class="mb-8 text-stone-400">Zarządzanie kampanią (tylko twórca / MG)</p>

<partial name="_ValidationSummary" />

<div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-lg">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-stone-500">Uczestnicy i postacie</h2>
        @if (Model.CampaignView.Members.Count == 0)
        {
            <p class="text-sm text-stone-500">Brak uczestników.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var member in Model.CampaignView.Members)
                {
                    <div class="rounded-lg border border-stone-800 bg-stone-800/30 px-4 py-3">
                        <p class="font-medium text-stone-200">@member.DisplayName</p>
                        @if (member.Characters.Count == 0)
                        {
                            <p class="mt-1 text-sm text-stone-500">Brak postaci</p>
                        }
                        else
                        {
                            <ul class="mt-2 flex flex-wrap gap-2">
                                @foreach (var character in member.Characters)
                                {
                                    <li>
                                        <a asp-page="/Characters/Details" asp-route-id="@character.CharacterId"
                                           class="text-sm text-amber-400 hover:text-amber-300">@character.Name</a>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>
        }
    </section>

    <section class="space-y-6">
        <div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-lg">
            <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-stone-500">Dodaj użytkownika</h2>
            <form method="post" asp-page-handler="AddMember" asp-route-id="@Model.CampaignId" class="space-y-3">
                <input asp-for="AddMemberEmail" type="email" placeholder="Adres e-mail"
                       class="w-full rounded-lg border border-stone-600 bg-stone-800 px-3 py-2 text-stone-100 placeholder-stone-500 focus:border-amber-600 focus:outline-none focus:ring-1 focus:ring-amber-600" />
                <span asp-validation-for="AddMemberEmail" class="block text-sm text-red-400"></span>
                <button type="submit" class="rounded-lg bg-amber-800 px-4 py-2 text-sm font-medium text-white transition hover:bg-amber-700">
                    Zaproś użytkownika
                </button>
            </form>
        </div>

        <div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-lg">
            <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-stone-500">Twoje postacie</h2>
            <p class="mb-4 text-sm text-stone-400">Dodaj lub usuń własne postacie w kampanii.</p>
            <a asp-page="/Campaigns/AddCharacter" asp-route-id="@Model.CampaignId"
               class="inline-block rounded-lg bg-emerald-800 px-4 py-2 text-sm font-medium text-white transition hover:bg-emerald-700">
                Zarządzaj postaciami
            </a>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
