@page
@model WFRP_Character_Companion.Pages.Campaigns.CreateModel
@{
    ViewData["Title"] = "Nowa kampania";
}

<h2 class="mb-4">Stwórz kampanię</h2>

<form method="post">
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label">Nazwa kampanii</label>
        <input asp-for="Input.Name" class="form-control" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Postacie w kampanii</label>
        @if (Model.UserCharacters.Count == 0)
        {
            <p class="text-muted">Nie masz jeszcze postaci do dodania.</p>
        }
        else
        {
            <div class="border rounded p-3">
                @foreach (var character in Model.UserCharacters)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="Input.CharacterIds"
                               value="@character.Id"
                               id="char_@character.Id" />
                        <label class="form-check-label" for="char_@character.Id">
                            @character.Name
                        </label>
                    </div>
                }
            </div>
        }
    </div>

    <div class="mb-3">
        <label asp-for="Input.MemberEmail" class="form-label">Zaproś użytkownika (e-mail)</label>
        <input asp-for="Input.MemberEmail" class="form-control" type="email" placeholder="opcjonalnie" />
        <span asp-validation-for="Input.MemberEmail" class="text-danger"></span>
        <div class="form-text">Zaproszony gracz zobaczy kampanię na swojej liście i doda własne postacie.</div>
    </div>

    <button type="submit" class="btn btn-primary">Utwórz kampanię</button>
    <a class="btn btn-outline-secondary" asp-page="/Campaigns/CampaignHub">Anuluj</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
