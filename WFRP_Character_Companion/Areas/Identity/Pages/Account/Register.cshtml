@page
@model WFRP_Character_Companion.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="mx-auto max-w-md">
    <h1 class="font-display mb-2 text-2xl font-bold text-amber-500">Rejestracja</h1>
    <p class="mb-6 text-sm text-stone-400">Utwórz konto w WFRP Companion.</p>

    <div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
        <form method="post" class="space-y-5">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="rounded-lg border border-red-900/50 bg-red-950/40 px-3 py-2 text-sm text-red-200"></div>

            <div>
                <label asp-for="Input.DisplayName" class="field-label"></label>
                <input asp-for="Input.DisplayName" class="field-input" autocomplete="nickname" />
                <span asp-validation-for="Input.DisplayName" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Input.Email" class="field-label"></label>
                <input asp-for="Input.Email" class="field-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="field-label"></label>
                <input asp-for="Input.Password" class="field-input" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword" class="field-label"></label>
                <input asp-for="Input.ConfirmPassword" class="field-input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="w-full rounded-lg bg-emerald-800 px-4 py-2.5 font-medium text-white transition hover:bg-emerald-700">
                Utwórz konto
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-stone-500">
            Masz już konto?
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-amber-400 hover:text-amber-300">Zaloguj się</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
