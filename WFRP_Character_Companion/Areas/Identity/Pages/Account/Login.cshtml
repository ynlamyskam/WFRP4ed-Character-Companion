@page
@model WFRP_Character_Companion.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Logowanie";
}

<div class="mx-auto max-w-md">
    <h1 class="font-display mb-2 text-2xl font-bold text-amber-500">Logowanie</h1>
    <p class="mb-6 text-sm text-stone-400">Zaloguj się do WFRP Companion.</p>

    <div class="rounded-xl border border-stone-700 bg-stone-900/80 p-6 shadow-xl">
        <form method="post" class="space-y-5">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="rounded-lg border border-red-900/50 bg-red-950/40 px-3 py-2 text-sm text-red-200"></div>

            <div>
                <label asp-for="Input.Email" class="field-label"></label>
                <input asp-for="Input.Email" class="field-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="field-label"></label>
                <input asp-for="Input.Password" class="field-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <label class="flex items-center gap-2 text-sm text-stone-400">
                <input asp-for="Input.RememberMe" class="h-4 w-4 rounded border-stone-600 bg-stone-800 text-amber-600 focus:ring-amber-600" />
                <span asp-for="Input.RememberMe"></span>
            </label>

            <button type="submit" class="w-full rounded-lg bg-amber-800 px-4 py-2.5 font-medium text-white transition hover:bg-amber-700">
                Zaloguj się
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-stone-500">
            Nie masz konta?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-amber-400 hover:text-amber-300">Zarejestruj się</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
